rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Patients can read/write their own data
    match /patients/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Pending - patients can create/read their own, admins can read/write all
    match /pending/{userId} {
      allow read, write: if request.auth != null;
    }
    // Queue - authenticated users can read, write
    match /queue/{docId} {
      allow read, write: if request.auth != null;
    }
    // Settings - authenticated users can read, admins can write
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    // Doctors - authenticated users can read
    match /doctors/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    // Departments
    match /departments/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
