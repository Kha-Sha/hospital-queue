rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public lead submissions from landing page — write-only, no auth required
    match /leads/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Global patient profiles — read/write own record only
    match /patients/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Global doctor lookup index — used by DoctorLogin to resolve hospitalId
    match /doctors/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Per-hospital namespace
    match /hospitals/{hospitalId} {

      // Hospital settings — any authenticated user can read; only admin (uid == hospitalId) can write
      match /settings/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == hospitalId;
      }

      // Pending arrivals — patients write their own; any authenticated user can read
      match /pending/{userId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if request.auth != null;
      }

      // Queue — any authenticated user can read/write (admin assigns, doctor completes, patient cancels)
      match /queue/{docId} {
        allow read, write: if request.auth != null;
      }

      // Departments — any authenticated user can read; admin/doctor can write
      match /departments/{deptName} {
        allow read, write: if request.auth != null;
      }

      // Doctor profiles scoped to this hospital
      match /doctors/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      // Admin accounts scoped to this hospital
      match /admins/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == hospitalId;
      }
    }
  }
}
