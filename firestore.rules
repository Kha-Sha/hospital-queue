rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin(hospitalId) {
      return request.auth != null &&
             request.auth.uid == hospitalId &&
             request.auth.token.email.matches('.*@hospital-admin\\.com');
    }

    function isDoctor() {
      return request.auth != null &&
             request.auth.token.email.matches('.*@hospital-doctor\\.com');
    }

    function isPatient() {
      return request.auth != null &&
             request.auth.token.email.matches('.*@hospital\\.com');
    }

    match /patients/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin(resource.data.hospitalId);
    }

    match /leads/{leadId} {
      allow create: if true;
      allow read, write: if false;
    }

    match /hospitals/{hospitalId}/{document=**} {
      allow read, write: if isAdmin(hospitalId);
    }

    match /hospitals/{hospitalId}/queue/{docId} {
      allow read: if request.auth != null &&
                     (request.auth.uid == resource.data.userId || isAdmin(hospitalId));
      allow write: if isAdmin(hospitalId);
    }

    match /hospitals/{hospitalId}/pending/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin(hospitalId) ||
                      (request.auth != null && request.auth.uid == userId);
    }

    match /hospitals/{hospitalId}/settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin(hospitalId);
    }

    match /hospitals/{hospitalId}/departments/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin(hospitalId) || isDoctor();
    }

    match /doctors/{doctorId} {
      allow read: if request.auth != null && request.auth.uid == doctorId;
      allow write: if isAdmin(resource.data.hospitalId) ||
                      isAdmin(request.resource.data.hospitalId);
    }

    match /hospitals/{hospitalId}/doctors/{doctorId} {
      allow read: if isAdmin(hospitalId) ||
                     (isDoctor() && request.auth.uid == doctorId);
      allow write: if isAdmin(hospitalId);
    }

    match /hospitals/{hospitalId}/admins/{adminId} {
      allow read, write: if isAdmin(hospitalId);
    }
  }
}
